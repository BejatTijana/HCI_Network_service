<UserControl x:Class="NetworkService.Views.AddEntityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:NetworkService.Controls"
             mc:Ignorable="d"
             Background="#1C2833">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Form fields -->
        <StackPanel Grid.Row="0" Margin="24,18,24,0">
            <TextBlock Text="ID (auto)" Foreground="#95A5A6" FontSize="12"/>
            <TextBox Text="{Binding ID, Mode=OneWay}" IsEnabled="False" Height="36"
                     Background="#34495E" BorderBrush="#34495E" Foreground="#ECF0F1"
                     Padding="8,0,0,0" VerticalContentAlignment="Center"
                     Margin="0,8,0,0"/>

            <TextBlock Text="Name*" Foreground="#95A5A6" FontSize="12" Margin="0,14,0,0"/>
            <Grid Margin="0,8,0,0">
                <TextBox x:Name="nameTB"
                         Text="{Binding Naziv, UpdateSourceTrigger=PropertyChanged}"
                         Height="36" Background="#2C3E50" BorderBrush="#34495E"
                         Foreground="#ECF0F1"
                         Padding="8,0,0,0" VerticalContentAlignment="Center"
                         ToolTip="Enter entity name"/>
                <TextBlock Text="Enter name..." Foreground="#7F8C8D"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Naziv}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <TextBlock Text="{Binding NazivError}" Foreground="#E74C3C" FontSize="11"
                       Margin="0,4,0,0"
                       Visibility="{Binding ShowNazivError, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="Type*" Foreground="#95A5A6" FontSize="12" Margin="0,14,0,0"/>
            <ComboBox ItemsSource="{Binding Types}"
                      SelectedItem="{Binding SelectedType}"
                      DisplayMemberPath="Ime"
                      Height="36" Margin="0,8,0,0"
                      Cursor="Hand" ToolTip="Select entity type">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <Border Background="#2C3E50" BorderBrush="#34495E" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="26"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="8,0,4,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedItem.Ime}"
                                                           Foreground="#ECF0F1" FontSize="13"
                                                           IsHitTestVisible="False"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#95A5A6"
                                                           FontSize="14" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                                            </Grid>
                                        </Border>
                                        <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      Background="Transparent" BorderThickness="0"
                                                      Focusable="False" Opacity="0"/>
                                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                               Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                            <Border Background="#2C3E50" BorderBrush="#34495E" BorderThickness="1"
                                                    MaxHeight="200">
                                                <ScrollViewer CanContentScroll="True">
                                                    <ItemsPresenter/>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.Style>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#ECF0F1"/>
                        <Setter Property="Background" Value="#2C3E50"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F618D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1F618D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>

            <TextBlock Text="Virtual keyboard" Foreground="#95A5A6" FontSize="11"
                       Margin="0,24,0,4"/>
            <controls:VirtualKeyboardControl TargetTextBox="{Binding ElementName=nameTB}"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="&#x2715; Cancel" Height="44"
                    Command="{Binding CancelCommand}"
                    Background="#34495E" Foreground="#ECF0F1"
                    FontSize="14" BorderBrush="#34495E" Cursor="Hand"
                    ToolTip="Cancel and return"/>
            <Button Grid.Column="2" Content="+ Add" Height="44"
                    Command="{Binding SaveCommand}"
                    Background="#1E8449" Foreground="#ECF0F1"
                    FontSize="14" BorderThickness="0" Cursor="Hand"
                    ToolTip="Save entity"/>
        </Grid>
    </Grid>
</UserControl>
