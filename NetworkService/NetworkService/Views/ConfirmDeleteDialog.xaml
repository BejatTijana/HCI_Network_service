<Window x:Class="NetworkService.Views.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Delete"
        Width="320" Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <StackPanel Margin="24">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap"
                   Foreground="#444444" FontSize="13" Margin="0,0,0,24"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" Height="40"
                    Click="Cancel_Click"
                    Background="White" Foreground="#444444"
                    BorderBrush="#CCCCCC" FontSize="13" Cursor="Hand"
                    ToolTip="Cancel deletion"/>
            <Button Grid.Column="2" Content="Delete" Height="40"
                    Click="Delete_Click"
                    Background="#CC3333" Foreground="White"
                    BorderThickness="0" FontSize="13" Cursor="Hand"
                    ToolTip="Confirm delete"/>
        </Grid>
    </StackPanel>
</Window>
