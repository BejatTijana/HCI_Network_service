<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:NetworkService.Controls"
             mc:Ignorable="d"
             Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MaxHeight="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search area -->
        <StackPanel Grid.Row="0" Margin="24,16,24,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Content="Name" IsChecked="{Binding SearchByName}"
                             Foreground="#444444" Margin="0,0,16,0" Cursor="Hand"
                             ToolTip="Search by entity name"/>
                <RadioButton Content="Type" IsChecked="{Binding SearchByType}"
                             Foreground="#444444" Cursor="Hand"
                             ToolTip="Search by entity type"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="searchTB"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Background="White" BorderBrush="#CCCCCC"
                             Padding="8,0,0,0" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Search..." Foreground="#AAAAAA"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Grid.Column="1" Content="X" Height="36"
                        Command="{Binding ClearSearchCommand}"
                        Background="#EEEEEE" BorderBrush="#CCCCCC"
                        FontSize="12" Cursor="Hand" ToolTip="Clear search"/>
            </Grid>
        </StackPanel>

        <!-- Table -->
        <ListView Grid.Row="1" Margin="24,8,24,8"
                  ItemsSource="{Binding FilteredEntities}"
                  SelectedItem="{Binding SelectedEntity, Mode=TwoWay}"
                  AlternationCount="2"
                  BorderBrush="#EEEEEE" BorderThickness="1"
                  ToolTip="Select entity to delete or view">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50"
                                    DisplayMemberBinding="{Binding ID}"/>
                    <GridViewColumn Header="Name"
                                    DisplayMemberBinding="{Binding Naziv}"/>
                    <GridViewColumn Header="Type" Width="120"
                                    DisplayMemberBinding="{Binding Tip.Ime}"/>
                    <GridViewColumn Header="MW" Width="60"
                                    DisplayMemberBinding="{Binding LastValue}"/>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#E8E8E8"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#CCDDFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="+ Add" Height="44"
                    Command="{Binding NavigateToAddCommand}"
                    Background="#555555" Foreground="White"
                    FontSize="14" BorderThickness="0" Cursor="Hand"
                    ToolTip="Add new entity"/>
            <Button Grid.Column="2" Content="Delete" Height="44"
                    Command="{Binding DeleteCommand}"
                    Background="White" Foreground="#444444"
                    FontSize="14" BorderBrush="#CCCCCC" Cursor="Hand"
                    ToolTip="Delete selected entity"/>
        </Grid>

        <!-- Keyboard -->
        <StackPanel Grid.Row="3" Margin="24,8,24,0">
            <TextBlock Text="Virtual keyboard" Foreground="#666666" FontSize="11" Margin="0,0,0,4"/>
            <controls:VirtualKeyboardControl TargetTextBox="{Binding ElementName=searchTB}"/>
        </StackPanel>
    </Grid>
</UserControl>
