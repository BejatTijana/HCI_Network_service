<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:NetworkService.Views"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             mc:Ignorable="d"
             Background="#1C2833">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MaxHeight="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search area -->
        <StackPanel Grid.Row="0" Margin="24,16,24,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Content="Name" IsChecked="{Binding SearchByName}"
                             Foreground="#ECF0F1" Margin="0,0,16,0" Cursor="Hand"
                             ToolTip="Search by entity name"/>
                <RadioButton Content="Type" IsChecked="{Binding SearchByType}"
                             Foreground="#ECF0F1" Cursor="Hand"
                             ToolTip="Search by entity type"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="searchTB"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Background="#2C3E50" BorderBrush="#34495E"
                             Foreground="#ECF0F1"
                             Padding="8,0,0,0" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Search..." Foreground="#7F8C8D"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Grid.Column="1" Content="X" Height="36"
                        Command="{Binding ClearSearchCommand}"
                        Background="#34495E" BorderBrush="#34495E"
                        FontSize="12" Cursor="Hand" ToolTip="Clear search"/>
            </Grid>
        </StackPanel>

        <!-- Table -->
        <ListView Grid.Row="1" Margin="24,8,24,8"
                  ItemsSource="{Binding FilteredEntities}"
                  SelectedItem="{Binding SelectedEntity, Mode=TwoWay}"
                  AlternationCount="2"
                  Background="#1C2833" BorderBrush="#34495E" BorderThickness="1"
                  ToolTip="Select entity to delete or view">
            <ListView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1E8449"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#ECF0F1"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2C3E50"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#ECF0F1"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1C2833"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1C2833"/>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50"
                                    DisplayMemberBinding="{Binding ID}"/>
                    <GridViewColumn Header="Name"
                                    DisplayMemberBinding="{Binding Naziv}"/>
                    <GridViewColumn Header="Type" Width="120"
                                    DisplayMemberBinding="{Binding Tip.Ime}"/>
                    <GridViewColumn Header="MW" Width="60"
                                    DisplayMemberBinding="{Binding LastValue}"/>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Foreground" Value="#ECF0F1"/>
                    <Setter Property="Background" Value="#2C3E50"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="#34495E">
                                    <GridViewRowPresenter
                                        Content="{TemplateBinding Content}"
                                        Columns="{TemplateBinding GridView.ColumnCollection}"
                                        Margin="0,4,0,4"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#253545"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1E8449"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="bd" Property="Background" Value="#1A5276"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#253545"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E8449"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="+ Add" Height="44"
                    Command="{Binding NavigateToAddCommand}"
                    Background="#1E8449" Foreground="#ECF0F1"
                    FontSize="14" BorderThickness="0" Cursor="Hand"
                    ToolTip="Add new entity"/>
            <Button Grid.Column="2" Content="Delete" Height="44"
                    Command="{Binding DeleteCommand}"
                    Background="#C0392B" Foreground="#ECF0F1"
                    FontSize="14" BorderBrush="#C0392B" Cursor="Hand"
                    ToolTip="Delete selected entity"/>
        </Grid>

        <!-- Keyboard -->
        <StackPanel Grid.Row="3" Margin="24,8,24,0">
            <TextBlock Text="Virtual keyboard" Foreground="#95A5A6" FontSize="11" Margin="0,0,0,4"/>
            <views:VirtualKeyboardControl vm:VirtualKeyboardAttacher.TargetTextBox="{Binding ElementName=searchTB}"/>
        </StackPanel>
    </Grid>
</UserControl>
