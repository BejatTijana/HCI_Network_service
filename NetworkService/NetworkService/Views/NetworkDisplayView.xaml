<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#1C2833">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="Entities" FontSize="12" Foreground="#95A5A6"
                   Margin="24,16,0,4"/>
        <Border Width="342" Height="120" BorderBrush="#34495E" BorderThickness="1"
                Background="#2C3E50" HorizontalAlignment="Left" Margin="24,0,0,0"
                AllowDrop="True"
                Drop="TV_Drop"
                DragOver="TV_AreaDragOver">
            <TreeView ItemsSource="{Binding EntityGroups}"
                      BorderThickness="0" Background="Transparent"
                      Cursor="Hand" ToolTip="Drag entity to place it on the grid"
                      PreviewMouseLeftButtonDown="TV_PreviewMouseDown"
                      MouseMove="TV_MouseMove">
                <TreeView.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1F618D"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#ECF0F1"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2C3E50"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#ECF0F1"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1C2833"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1C2833"/>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground" Value="#ECF0F1"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Entities}">
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Naziv, StringFormat='&#x2022; {0}'}"
                                           Foreground="#95A5A6" FontSize="12"/>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                        <TextBlock Text="{Binding TypeName, StringFormat='&#x25BC; {0}'}"
                                   Foreground="#ECF0F1" FontSize="12"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
        <TextBlock Text="Drag &amp; Drop grid" FontSize="12" Foreground="#95A5A6"
                   Margin="24,16,0,8"/>
        <Grid Margin="24,0,24,0">
        <ItemsControl x:Name="SlotsControl" ItemsSource="{Binding CanvasSlots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Width="76" Height="70" Margin="2"
                          AllowDrop="True"
                          Drop="Slot_Drop"
                          DragOver="Slot_DragOver"
                          PreviewMouseLeftButtonDown="Slot_PreviewMouseDown"
                          MouseMove="Slot_SlotMouseMove"
                          MouseLeftButtonUp="Slot_MouseUp"
                          ToolTip="{Binding DisplayText}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="2"
                                                                  Opacity="0.25" Color="Black"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Rectangle Grid.RowSpan="2" RadiusX="10" RadiusY="10"
                                   Fill="#2C3E50" Stroke="#34495E" StrokeThickness="1">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                            <Setter Property="StrokeDashArray" Value="4,2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <Image Grid.Row="0"
                               Source="{Binding Entity.Tip.Slika}"
                               Width="28" Height="28"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               SnapsToDevicePixels="True"
                               Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding DisplayText}"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   FontSize="9"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#ECF0F1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border Grid.RowSpan="2" BorderThickness="2" IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectedForConnection}" Value="True">
                                            <Setter Property="BorderBrush" Value="#F39C12"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ItemsControl ItemsSource="{Binding ConnectionLines}" IsHitTestVisible="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsHitTestVisible="False"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                          Stroke="#2ECC71" StrokeThickness="2.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          IsHitTestVisible="False"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>
    </StackPanel>
</UserControl>
